// [7] alert_log - 경고 로그
Table alert_log {
  alert_id     BIGINT  [pk, increment]
  robot_id     INT     [ref: > robot.robot_id]
  severity     ENUM('info','warning','critical') [not null]
  alert_type   ENUM('low_battery','obstacle','comm_lost','cart_full','task_timeout') [not null]
  message      VARCHAR(500)
  resolved     BOOLEAN   [default: false]
  triggered_at TIMESTAMP [default: `CURRENT_TIMESTAMP`]
}
